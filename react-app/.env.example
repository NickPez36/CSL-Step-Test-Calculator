# Copy to .env.local and fill in from Firebase project settings (General → Your apps).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: override default login emails (defaults are viewer@csl-step.local / admin@csl-step.local — must match Firebase users and firestore.rules).
# VITE_AUTH_VIEWER_EMAIL=
# VITE_AUTH_ADMIN_EMAIL=
