# Optional: Firebase Firestore for shared session library (recommended for multi-user / multi-device).
# Copy to ".env.local" in this folder (Vite loads .env.local automatically; do not commit secrets).
# Get values from Firebase Console → Project settings → Your apps → Web app config.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: base URL of the self-hosted sessions API (Express). Ignored when Firestore is configured.
# VITE_SESSIONS_API_BASE=https://your-api.example.com
