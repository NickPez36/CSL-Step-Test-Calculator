# Optional: persist sessions to server/data/sessions.json in the repo via GitHub Contents API.
# Copy to ".env" for local API only. Never commit .env or paste tokens into the React app.
#
# Revoke any token that was exposed (e.g. in chat, screenshots, or a public repo) and create a new one.

GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_SESSIONS_PATH=server/data/sessions.json

# For the Vite app build (production): base URL of the deployed sessions API (no trailing slash).
# VITE_SESSIONS_API_BASE=https://your-sessions-api.example.com
